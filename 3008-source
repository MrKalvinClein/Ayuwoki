local function createESP(object, color, customName)
    local hrp = object:FindFirstChild("HumanoidRootPart") or object:FindFirstChild("Root") or object:FindFirstChildWhichIsA("Part") or object:FindFirstChildWhichIsA("MeshPart")
    if not hrp then return nil end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = object
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = object
    
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Adornee = hrp
    billboardGui.Size = UDim2.new(0, 200, 0, 50)
    billboardGui.StudsOffset = Vector3.new(0, 3, 0)
    billboardGui.AlwaysOnTop = true
    billboardGui.Parent = hrp
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = color
    textLabel.TextStrokeTransparency = 0.5
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.Parent = billboardGui
    
    local esp = {
        Object = object,
        Highlight = highlight,
        BillboardGui = billboardGui,
        TextLabel = textLabel,
        CustomName = customName
    }
    
    return esp
end

local function removeESP(esp)
    if esp.Highlight then
        esp.Highlight:Destroy()
    end
    if esp.BillboardGui then
        esp.BillboardGui:Destroy()
    end
end

local function updateESP()
    for _, esp in pairs(ESPObjects) do
        if esp.Object and esp.Object.Parent and esp.TextLabel then
            local hrp = esp.Object:FindFirstChild("HumanoidRootPart") or esp.Object:FindFirstChild("Root") or esp.Object:FindFirstChildWhichIsA("Part") or esp.Object:FindFirstChildWhichIsA("MeshPart")
            
            if hrp and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                local distance = (Player.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                local displayName = esp.CustomName or esp.Object.Name
                esp.TextLabel.Text = displayName .. "\n[" .. math.floor(distance) .. "m]"
            end
        end
    end
end

local function clearESP()
    for _, esp in pairs(ESPObjects) do
        removeESP(esp)
    end
    ESPObjects = {}
end

local function refreshESP()
    clearESP()
    
    if ESPSettings.Players then
        for _, player in pairs(PS:GetPlayers()) do
            if player ~= Player and player.Character then
                local esp = createESP(player.Character, Color3.fromRGB(255, 165, 0), player.DisplayName)
                if esp then
                    table.insert(ESPObjects, esp)
                end
            end
        end
    end
    
    if ESPSettings.Employees then
        for _, employee in pairs(WS.GameObjects.Physical.Employees:GetChildren()) do
            if employee:IsA("Model") then
                local esp = createESP(employee, Color3.fromRGB(255, 0, 0), "Employee")
                if esp then
                    table.insert(ESPObjects, esp)
                end
            end
        end
    end
    
    if ESPSettings.Food then
        local count = 0
        for _, item in pairs(ItemsFolder:GetChildren()) do
            if item:IsA("Model") and count < 50 then
                local esp = createESP(item, Color3.fromRGB(0, 150, 255), item.Name)
                if esp then
                    table.insert(ESPObjects, esp)
                    count = count + 1
                end
            end
        end
    end
end

